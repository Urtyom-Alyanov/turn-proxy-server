# Maintainer: Urtyom Alyanov <urtyomalynov@gmail.com>
pkgname=turn-proxy-server-rs
pkgver=1.0.20
pkgrel=1
pkgdesc="DTLS proxy server for TURN-based video call traffic relay"
arch=('x86_64' 'aarch64')
url="https://github.com/Urtyom-Alyanov/turn-proxy"
license=('AGPL3')
depends=('gcc-libs')
makedepends=('rust' 'cargo')
source=("$pkgname-$pkgver.tar.gz::https://github.com/Urtyom-Alyanov/turn-proxy/archive/v$pkgver.tar.gz")
sha256sums=('SKIP')

prepare() {
    cd "turn-proxy-$pkgver"
    cargo fetch --locked --target "$CARCH-unknown-linux-gnu"
}

build() {
    cd "turn-proxy-$pkgver"
    export RUSTUP_TOOLCHAIN=stable
    cargo build -p turn-proxy-server --frozen --release --all-features
}

check() {
    cd "turn-proxy-$pkgver"
    cargo test -p turn-proxy-server --frozen
}

package() {
    cd "turn-proxy-$pkgver"

    # Установка бинарника
    install -Dm755 "target/release/turn-proxy-server" "$pkgdir/usr/bin/turn-proxy-server"

    # Установка конфига по умолчанию
    install -Dm644 "server/example.toml" "$pkgdir/etc/turn-proxy/server/config.toml"

    if [ -f "server/services/systemd/turn-proxy-server.service" ]; then
        install -Dm644 "server/services/systemd/turn-proxy-server.service" "$pkgdir/usr/lib/systemd/system/turn-proxy-server.service"
    fi

    install -Dm644 server/LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
    install -Dm644 server/README.md "$pkgdir/usr/share/doc/$pkgname/README.md"
}
