# Maintainer: Urtyom Alyanov <urtyomalynov@gmail.com>
pkgname=turn-proxy-client-rs
pkgver=1.0.20
pkgrel=1
pkgdesc="DTLS proxy client for TURN-based video call traffic relay"
arch=('x86_64' 'aarch64')
url="https://github.com/Urtyom-Alyanov/turn-proxy"
license=('MPL2')
depends=('gcc-libs')
makedepends=('rust' 'cargo')
source=("$pkgname-$pkgver.tar.gz::https://github.com/Urtyom-Alyanov/turn-proxy/archive/v$pkgver.tar.gz")
sha256sums=('SKIP')

prepare() {
    cd "turn-proxy-$pkgver"
    cargo fetch --locked --target "$CARCH-unknown-linux-gnu"
}

build() {
    cd "turn-proxy-$pkgver"
    export RUSTUP_TOOLCHAIN=stable
    cargo build -p turn-proxy-client --frozen --release --all-features
}

check() {
    cd "turn-proxy-$pkgver"
    cargo test -p turn-proxy-client --frozen
}

package() {
    cd "turn-proxy-$pkgver"

    # Установка бинарника
    install -Dm755 "target/release/turn-proxy-client" "$pkgdir/usr/bin/turn-proxy-client"

    # Установка конфига по умолчанию
    install -Dm644 "client/example.toml" "$pkgdir/etc/turn-proxy/client/config.toml"

    if [ -f "server/services/systemd/turn-proxy-client.service" ]; then
        install -Dm644 "client/services/systemd/turn-proxy-client.service" "$pkgdir/usr/lib/systemd/system/turn-proxy-client.service"
    fi

    install -Dm644 client/LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
    install -Dm644 client/README.md "$pkgdir/usr/share/doc/$pkgname/README.md"
}
